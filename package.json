{
  "name": "opencons",
  "version": "0.2.0",
  "description": "Opencons — live runtime execution tracer for Node.js / Express",
  "main": "src/index.js",
  "types": "opencons.d.ts",
  "exports": {
    ".": {
      "types": "./opencons.d.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./register-transform": {
      "require": "./src/transform/register.js",
      "default": "./src/transform/register.js"
    }
  },
  "files": [
    "src",
    "widget",
    "opencons.d.ts",
    "scripts/vendor-d3.js"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "start:example": "node examples/sample-app/server.js",
    "postinstall": "node scripts/vendor-d3.js"
  },
  "keywords": [
    "express",
    "tracing",
    "debugging",
    "middleware",
    "developer-tools"
  ],
  "author": "patiencemanzen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patiencemanzen/opencons.git"
  },
  "homepage": "https://github.com/patiencemanzen/opencons#readme",
  "bugs": {
    "url": "https://github.com/patiencemanzen/opencons/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.27.0",
    "ws": "^8.17.0"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "d3": "^7.9.0",
    "express": "^4.21.0",
    "rxjs": "^7.8.1"
  }
}
