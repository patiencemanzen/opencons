{
  "name": "routegrapher",
  "version": "0.1.0",
  "description": "Live runtime execution tracer for Node.js / Express — zero-config request-scoped visual tracing",
  "main": "src/index.js",
  "types": "routegrapher.d.ts",
  "exports": {
    ".": {
      "types": "./routegrapher.d.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./register-transform": {
      "require": "./src/transform/register.js",
      "default": "./src/transform/register.js"
    }
  },
  "files": [
    "src",
    "widget",
    "routegrapher.d.ts",
    "scripts/vendor-d3.js"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "start:example": "node examples/sample-app/server.js",
    "postinstall": "node scripts/vendor-d3.js"
  },
  "keywords": [
    "express",
    "tracing",
    "debugging",
    "middleware",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@babel/generator": "^7.27.0",
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.27.0",
    "ws": "^8.17.0"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "d3": "^7.9.0",
    "express": "^4.21.0",
    "rxjs": "^7.8.1"
  }
}
